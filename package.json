{
  "name": "payment-system",
  "version": "1.0.0",
  "description": "Secure NestJS authentication and billing system",
  "main": "dist/main.js",
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "build:clean": "npm run build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "migration:generate": "npm run typeorm -- migration:generate src/infrastructure/database/migrations/AutoMigration",
    "migration:create": "typeorm-ts-node-commonjs migration:create src/infrastructure/database/migrations/ManualMigration",
    "migration:run": "typeorm-ts-node-commonjs -d src/infrastructure/database/typeorm.config.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/infrastructure/database/typeorm.config.ts migration:revert",
    "seed": "ts-node -r tsconfig-paths/register src/infrastructure/database/seed/seed.bootstrap.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/infrastructure/database/typeorm.config.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.26.1",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.7.2"
  },
  "private": true
}
